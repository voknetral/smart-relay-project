{
    "cli": {
        "version": ">= 5.9.1",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk",
                "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=armeabi-v7a"
            }
        },
        "production": {
            "android": {
                "gradleCommand": ":app:bundleRelease -PreactNativeArchitectures=armeabi-v7a"
            }
        }
    },
    "submit": {
        "production": {}
    }
}
